/* Core Styling Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
    scroll-behavior: smooth;
}

body {
    background-color: #0b0f19; /* High tech dark background */

    color: #f1f5f9;
    line-height: 1.6;
}

/* Header & Nav Layout */
header {
    background-color: #0f172a;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #1e293b;
    position: sticky;
    top: 0;
    z-index: 100;
}

.logo {
    font-size: 22px;
    font-weight: 800;
    color: #6366f1; /* Electric Indigo */
}

nav a {
    text-decoration: none;
    color: #94a3b8;
    margin: 0 12px;
    font-weight: 600;
    font-size: 15px;
}

nav a:hover {
    color: #6366f1;
}

.btn-nav {
    background-color: #6366f1;
    color: white !important;
    padding: 6px 16px;
    border-radius: 20px;
}

/* Premium Tech Hero */
.hero {
    background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.15), transparent), #0f172a;
    text-align: center;
    padding: 70px 20px;
    border-bottom: 1px solid #1e293b;
}

.hero-content h1 {
    font-size: 34px;
    font-weight: 800;
    margin-bottom: 12px;
    letter-spacing: -0.5px;
    color: #ffffff;
}

.hero-content p {
    font-size: 16px;
    max-width: 580px;
    margin: 0 auto 30px;
    color: #94a3b8;
}

/* Interactive Mobile Search Box */
.search-box {
    background: #1e293b;
    padding: 6px;
    border-radius: 30px;
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    border: 1px solid #334155;
}

.search-box input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 10px 15px;
    font-size: 15px;
    outline: none;
    color: white;
}

.search-box input::placeholder {
    color: #64748b;
}

.btn-search {
    background-color: #6366f1;
    color: white;
    border: none;
    padding: 10px 24px;
    font-weight: bold;
    border-radius: 25px;
    cursor: pointer;
}

/* Stats Styling */
.stats {
    background-color: #0f172a;
    display: flex;
    justify-content: space-around;
    padding: 24px 10px;
    text-align: center;
    border-bottom: 1px solid #1e293b;
}

.stat-item h3 {
    color: #6366f1;
    font-size: 26px;
    font-weight: 800;
}

.stat-item p {
    color: #64748b;
    font-size: 13px;
    font-weight: 600;
}

/* Job Feed Layout */
.jobs-section {
    max-width: 850px;
    margin: 50px auto;
    padding: 0 16px;
}

.jobs-section h2 {
    font-size: 28px;
    color: white;
}

.subtitle {
    color: #94a3b8;
    margin-bottom: 25px;
    font-size: 15px;
}

/* Filter Tags Layout */
.category-filters {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 15px;
    margin-bottom: 25px;
}

.filter-btn {
    background-color: #1e293b;
    color: #94a3b8;
    border: 1px solid #334155;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 20px;
    white-space: nowrap;
    cursor: pointer;
}

.filter-btn.active {
    background-color: rgba(99, 102, 241, 0.2);
    color: #a5b4fc;
    border-color: #6366f1;
}

.job-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* Glassmorphism Job Cards */
.job-card {
    background: #0f172a;
    padding: 24px;
    border-radius: 16px;
    border: 1px solid #1e293b;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: transform 0.2s, border-color 0.2s;
}

.job-card:hover {
    transform: translateY(-2px);
    border-color: #334155;
}

.job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
}

.job-header h3 {
    font-size: 19px;
    color: white;
}

.company {
    font-size: 14px;
    color: #94a3b8;
    margin-top: 2px;
}

/* Job Badges Styling */
.tag-type {
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 12px;
    text-transform: uppercase;
}

.full-time { background-color: rgba(34, 197, 94, 0.15); color: #4ade80; }
.contract { background-color: rgba(234, 179, 8, 0.15); color: #facc15; }
.part-time { background-color: rgba(168, 85, 247, 0.15); color: #c084fc; }

.job-desc {
    font-size: 14px;
    color: #cbd5e1;
    margin-bottom: 20px;
}

.job-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #1e293b;
    padding-top: 15px;
}

.tag-salary {
    font-size: 14px;
    font-weight: 700;
    color: #f8fafc;
}

.btn-apply {
    background-color: #6366f1;
    color: white;
    text-decoration: none;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: bold;
    border-radius: 8px;
}

/* Pricing Grid Sections */
.pricing-section {
    background-color: #0f172a;
    padding: 60px 16px;
    text-align: center;
    border-top: 1px solid #1e293b;
    border-bottom: 1px solid #1e293b;
}

.pricing-section h2 { font-size: 28px; color: white; }

.pricing-grid {
    display: flex;
    flex-direction: column;
    max-width: 800px;
    margin: 40px auto 0;
    gap: 25px;
}

@media (min-width: 650px) {
    .pricing-grid { flex-direction: row; }
}

.price-card {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 16px;
    padding: 30px 24px;
    flex: 1;
    text-align: left;
    position: relative;
    display: flex;
    flex-direction: column;
}

.featured-plan {
    border-color: #6366f1;
    background: linear-gradient(rgba(15, 23, 42, 0.4), rgba(15, 23, 42, 0.4)), #1e293b;
    box-shadow: 0 10px 30px rgba(99,102,241,0.15);
}

.popular-badge {
    position: absolute;
    top: -12px;
    right: 20px;
    background-color: #6366f1;
    color: white;
    font-size: 11px;
    font-weight: bold;
    padding: 4px 12px;
    border-radius: 12px;
}

.price-card h3 { color: white; font-size: 20px; margin-bottom: 10px; }

.price { font-size: 32px; font-weight: 800; color: white; margin-bottom: 15px; }
.price span { font-size: 14px; color: #94a3b8; font-weight: 400; }

.price-card p { font-size: 14px; color: #cbd5e1; margin-bottom: 20px; }

.price-card ul { list-style: none; margin-bottom: 30px; flex-grow: 1; }
.price-card ul li { font-size: 13px; color: #94a3b8; margin-bottom: 10px; }
.price-card ul li::before { content: "✓ "; color: #6366f1; font-weight: bold; }

.btn-price {
    width: 100%;
    background-color: #334155;
    border: none;
    color: white;
    padding: 12px;
    font-weight: 700;
    border-radius: 8px;
    cursor: pointer;
}

.premium-btn { background-color: #6366f1; }

/* Dynamic Application Form Layout */
.application-section {
    max-width: 650px;
    margin: 60px auto;
    padding: 0 16px;
}

.form-container {
    background: #0f172a;
    padding: 35px 25px;
    border-radius: 20px;
    border: 1px solid #1e293b;
}

.form-container h2 { text-align: center; color: white; font-size: 26px; }

.form-group { margin-bottom: 16px; }
.form-group input, 
.form-group select, 
.form-group textarea {
    width: 100%;
    padding: 14px;
    border: 1px solid #334155;
    border-radius: 10px;
    background-color: #1e293b;
    color: white;
    font-size: 15px;
    outline: none;
}

.form-group input:focus, 
.form-group select:focus, 
.form-group textarea:focus {
    border-color: #6366f1;
}

.btn-submit-app {
    width: 100%;
    background-color: #6366f1;
    color: white;
    border: none;
    padding: 14px;
    font-size: 16px;
    font-weight: bold;
    border-radius: 10px;
    cursor: pointer;
}

/* Premium Footer In Series Layout */
footer {
    background-color: #090d16;
    color: #94a3b8;
    padding: 50px 20px 25px;
    font-size: 14px;
    border-top: 1px solid #1e293b;
}

.footer-layout {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 30px;
    text-align: center;
}

@media (min-width: 550px) {
    .footer-layout { flex-direction: row; justify-content: space-between; text-align: left; }
}

footer h3 { color: white; font-size: 16px; margin-bottom: 12px; }

/* Force Social Buttons to be Horizontal/In-Series */
.social-series {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
}

@media (min-width: 550px) {
    .social-series { justify-content: flex-start; }
}

.social-link {
    text-decoration: none;
    font-size: 13px;
    font-weight: bold;
    padding: 8px 16px;
    border-radius: 20px;
    color: white !important;
}

.x-logo { background-color: #111827; border: 1px solid #334155; }
.li-logo { background-color: #0a66c2; }
.gh-logo { background-color: #24292e; }

.footer-hr { border: 0; border-top: 1px solid #1e293b; margin: 30px 0 20px; }
.copyright { text-align: center; font-size: 12px; color: #64748b; }
/* Premium Gmail Login Modal Styling */
.login-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(11, 15, 25, 0.85);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.login-card {
    background-color: #0f172a;
    border: 1px solid #1e293b;
    padding: 40px 30px;
    border-radius: 20px;
    width: 90%;
    max-width: 400px;
    position: relative;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
}

.close-modal {
    position: absolute;
    top: 15px;
    right: 20px;
    font-size: 24px;
    color: #64748b;
    cursor: pointer;
}

.login-card h2 { color: white; font-size: 24px; margin-bottom: 6px; }
.login-card p { color: #94a3b8; font-size: 14px; margin-bottom: 25px; }

/* Gmail Auth Button Design */
.btn-google-login {
    width: 100%;
    background-color: #ffffff;
    color: #1e293b;
    border: none;
    padding: 12px;
    font-size: 15px;
    font-weight: 700;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    box-shadow: 0 4px 12px rgba(255,255,255,0.05);
}

.btn-google-login img {
    width: 18px;
    height: 18px;
}

.login-divider {
    margin: 20px 0;
    position: relative;
    text-align: center;
}
.login-divider::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: #1e293b;
    z-index: 1;
}
.login-divider span {
    background-color: #0f172a;
    padding: 0 10px;
    color: #64748b;
    font-size: 12px;
    position: relative;
    z-index: 2;
    text-transform: uppercase;
}

.modal-input {
    width: 100%;
    padding: 12px;
    background-color: #1e293b;
    border: 1px solid #334155;
    color: white;
    border-radius: 10px;
    margin-bottom: 15px;
    outline: none;
}

.btn-submit-login {
    width: 100%;
    background-color: #6366f1;
    color: white;
    border: none;
    padding: 12px;
    font-size: 15px;
    font-weight: 700;
    border-radius: 10px;
    cursor: pointer;
}